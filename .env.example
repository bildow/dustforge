PORT=3001
DB_PATH=./data/dustforge.db

# Stalwart mail server (via Tailscale or direct)
STALWART_HOST=100.83.112.88
STALWART_PORT=8090
STALWART_USER=admin
STALWART_PASS=

# Identity encryption — REQUIRED, server will not start without this
IDENTITY_MASTER_KEY=

# Stripe (test mode keys for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URLs
PLATFORM_BASE_URL=https://dustforge.com
REFERRAL_BASE_URL=https://dustforge.com/join

# SMTP relay (RackNerd local Postfix)
SMTP_HOST=localhost
SMTP_PORT=25
